{
  "name": "s4-textile-backend",
  "version": "1.0.0",
  "description": "Express backend for S4 Creative Textile AI Studio",
  "main": "dist/index.js",
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--max-old-space-size=4096 tsx watch --env-file=.env src/index.ts",
    "build": "tsc",
    "start": "cross-env NODE_OPTIONS=--max-old-space-size=4096 node dist/index.js"
  },
  "dependencies": {
    "@google/genai": "1.34.0",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.14.0",
    "cross-env": "^10.1.0",
    "tsx": "^4.19.2",
    "typescript": "~5.8.2"
  }
}
